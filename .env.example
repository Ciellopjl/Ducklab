# ============================================================================
# VARIÁVEIS DE AMBIENTE — TEMPLATE
# ============================================================================
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o arquivo .env com credenciais reais!
# ============================================================================

# Banco de dados (Neon, Supabase, etc)
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# Email do administrador master (BOSS) — OBRIGATÓRIO
ADMIN_EMAIL="seu-email@gmail.com"

# Ambiente
NODE_ENV="development"

# NextAuth — Gerar um secret forte: openssl rand -hex 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="gere-um-secret-com-openssl-rand-hex-32"

# Google OAuth — Obter em https://console.cloud.google.com
GOOGLE_CLIENT_ID="seu-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="seu-client-secret"
