# ============================================================================
# GITIGNORE — PROTEÇÃO MÁXIMA DE CREDENCIAIS
# ============================================================================

# dependências
/node_modules
/.pnp
.pnp.js

# testes
/coverage

# next.js
/.next/
/out/

# produção
/build

# misc
.DS_Store
*.pem
Thumbs.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================================================
# 🔒 PROTEÇÃO DE CREDENCIAIS E SECRETS
# ============================================================================

# Arquivos de ambiente (NUNCA commitar!)
.env
.env.*
.env.local
.env.development
.env.production
.env.staging
!.env.example

# Chaves e certificados
*.key
*.cert
*.crt
*.csr
*.p12
*.pfx

# ============================================================================
# 🔒 PROTEÇÃO DE DADOS LOCAIS
# ============================================================================

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# banco de dados local
*.db
*.db-journal
*.sqlite
*.sqlite3

# logs sensíveis (podem conter emails e IPs)
auditoria_emergencia.log
heartbeat.log
*.log

# uploads do usuário
/public/uploads/*
!/public/uploads/.gitkeep

